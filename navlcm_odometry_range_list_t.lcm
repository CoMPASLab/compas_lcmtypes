package navlcm;

/* Message containing odometry and range setpoints inside lists of arbitrary size.
 */

struct odometry_range_list_t
{
	// Standard header.
    stdlcm.header_t header;

	// List of poses
	int16_t n_poses;
    geolcm.pose_t poses[n_poses];

	// List of twists
	int16_t n_twists;
	geolcm.twist_t twists[n_twists];

	// List of ranges (e.g. altitudes)
	int16_t n_ranges;
	double ranges[n_ranges];
}
